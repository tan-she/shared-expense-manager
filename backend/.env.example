# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── PostgreSQL ────────────────────────────────────────────────
# Local:  postgres://user:password@localhost:5432/shared_expenses
# Neon:   postgres://user:password@ep-xxx.neon.tech/shared_expenses?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shared_expenses

# ── JWT ───────────────────────────────────────────────────────
# Use a long random string in production. Never expose this.
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────────
# URL of the React frontend
FRONTEND_URL=http://localhost:5173
